# ─────────────────────────────────────────────
# AttendEase Server — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/<db>?retryWrites=true&w=majority

# ── Server ───────────────────────────────────
PORT=5000
NODE_ENV=production

# ── JWT ──────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=1d

# ── CORS / Client origin ─────────────────────
# Production (Vercel):  CLIENT_URL=https://<your-app>.vercel.app
# For local dev:        CLIENT_URL=http://localhost:5173
# For ngrok session:    CLIENT_URL=https://<id>.ngrok-free.app
#
# NOTE: When NODE_ENV=development the server already accepts ALL
# *.ngrok-free.app and *.ngrok.io origins automatically (see server.js),
# so you only need to update this value if NODE_ENV=production.
CLIENT_URL=https://<your-vercel-app>.vercel.app

# ── GPS / Attendance ─────────────────────────
GPS_RADIUS_METERS=1000
GPS_ENFORCE=true

# ── College domain ───────────────────────────
COLLEGE_DOMAIN=yourdomain.edu

# ── Email / SMTP (optional) ──────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
